# ============================================================
# MethyAgent — Environment Variables
#
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# ============================================================

# ---- ZhipuAI 智谱 (recommended, used by default) ----
# Get key at: https://open.bigmodel.cn → 控制台 → API Keys
ZHIPU_API_KEY=your_zhipu_api_key_here
# Model options: glm-4-flash (free) | glm-4-air | glm-4 | glm-4-long
ZHIPU_MODEL=glm-4-flash

# ---- OpenAI (or compatible API, alternative to ZhipuAI) ----
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# ---- Anthropic (alternative LLM backend) ----
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---- DeepSeek (alternative LLM backend, OpenAI-compatible) ----
# Get key at: https://platform.deepseek.com → API Keys
# Model options: deepseek-chat (V3) | deepseek-reasoner (R1)
# DEEPSEEK_API_KEY=sk-...
# DEEPSEEK_MODEL=deepseek-chat

# ---- NCBI / GEO (required for agent1 database searches) ----
# Register at: https://www.ncbi.nlm.nih.gov/account/
NCBI_API_KEY=your_ncbi_api_key_here
GEO_EMAIL=your@email.com

# ---- TCGA / GDC (optional, for TCGA downloads via agent1) ----
# Get token from: https://portal.gdc.cancer.gov/ → your profile → Download Token
# GDC_TOKEN=your_gdc_token_here

# ---- Logging ----
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# ---- Agent daemon tuning (optional) ----
# POLL_INTERVAL=5          # Seconds between task queue polls
# HEARTBEAT_INTERVAL=30    # Seconds between heartbeat writes
# HEARTBEAT_STALE_SECS=120 # Seconds before a heartbeat is considered stale
